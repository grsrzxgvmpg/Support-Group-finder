# Server-side API key (used by Vercel serverless function)
# Get your free API key at https://serper.dev (2,500 queries/month free)
# Add this in Vercel Dashboard > Project Settings > Environment Variables
SERPER_API_KEY=your_serper_api_key_here

# Base URL of the deployed backend, baked in at BUILD time.
# - Web builds: leave empty (the app calls the same-origin /api/search)
# - Native Android/iOS builds: REQUIRED - the app shell has no backend, so
#   point this at your deployed web app, e.g. https://your-app.vercel.app
#   Without it, native builds only show the curated fallback resources.
VITE_API_BASE_URL=

# Meeting Guide JSON feeds for real 12-step meeting schedules (day/time/types).
# Comma-separated list of Meeting Guide feed URLs (the open format used by
# AA/NA/Al-Anon intergroups - see github.com/code4recovery/spec). Used
# server-side only, so no CORS issues. Recovery/addiction searches will then
# surface real meetings with verified times and an "Add to calendar" option.
# Leave empty to disable the feature (the app is unaffected).
# Example (online AA meetings nationwide + a local intergroup):
#   MEETING_GUIDE_FEEDS=https://aa-intergroup.org/feed.json,https://your-area-aa.org/wp-admin/admin-ajax.php?action=meetings
MEETING_GUIDE_FEEDS=
